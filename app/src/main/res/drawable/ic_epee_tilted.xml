<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ Simple vectorial epee tilted 25° clockwise from vertical
  ~ Copyright (C) 2026
  -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Background circle -->
    <path
        android:fillColor="#FF6200EA"
        android:pathData="M54,54m-50,0a50,50 0,1 1,100 0a50,50 0,1 1,-100 0"/>
    
    <!-- Epee blade (tilted 25° clockwise from vertical) -->
    <!-- Starting from center (54,20) going down and slightly right -->
    <path
        android:fillColor="#C0C0C0"
        android:strokeWidth="2"
        android:strokeColor="#999999"
        android:pathData="M54,20 L60,75 L58,76 L52,21 Z"/>
    
    <!-- Epee guard (circular, positioned at the base of blade) -->
    <path
        android:fillColor="#C0C0C0"
        android:pathData="M54,20m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0"/>
    
    <!-- Epee handle (below guard, tilted same angle) -->
    <path
        android:fillColor="#8B4513"
        android:pathData="M54,20 L56,30 L55,31 L53,21 Z"/>
    
    <!-- Epee pommel (small circle at end of handle) -->
    <path
        android:fillColor="#666666"
        android:pathData="M55,30m-1.5,0a1.5,1.5 0,1 1,3 0a1.5,1.5 0,1 1,-3 0"/>
    
</vector>