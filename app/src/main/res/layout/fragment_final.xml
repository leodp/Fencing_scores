<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D0D0D0"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title left, Save button right -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/final_titleText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Final Rankings"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="start"
                android:shadowColor="#888888"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="3" />

            <Button
                android:id="@+id/final_saveBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SAVE"
                android:backgroundTint="#D32F2F"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <!-- Container for 3 rankings columns -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- Left rankings column -->
            <LinearLayout
                android:id="@+id/final_rankingsLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="4dp"
                android:layout_marginEnd="16dp" />

            <!-- Middle rankings column -->
            <LinearLayout
                android:id="@+id/final_rankingsLayoutMiddle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="4dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp" />

            <!-- Right rankings column -->
            <LinearLayout
                android:id="@+id/final_rankingsLayoutRight"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="4dp"
                android:layout_marginStart="16dp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
