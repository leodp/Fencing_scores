<?xml version="1.0" encoding="utf-8"?>
<!-- Launcher icon using fencer image (MDPI) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background circle -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#FF6200EA" />
            <size android:width="48dp" android:height="48dp" />
        </shape>
    </item>
    <!-- Fencer image overlay -->
    <item android:drawable="@drawable/fencer" 
          android:gravity="center"
          android:width="40dp" 
          android:height="40dp"/>
</layer-list>